    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #FF7043; /* Oranye Cerah */
            --secondary: #FFB74D;
            --bg: #FFF9F0; /* Krem Lembut */
            --text: #4E342E;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: var(--bg); color: var(--text); font-family: 'Quicksand', sans-serif; }

        header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            text-align: center;
            padding: 50px 20px;
            border-bottom-left-radius: 50px;
            border-bottom-right-radius: 50px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        h1 { font-family: 'Fredoka', sans-serif; font-size: 2.5rem; margin-bottom: 10px; }
        .tagline { font-style: italic; opacity: 0.9; }

        .container { max-width: 1000px; margin: auto; padding: 40px 20px; }

        .menu-title { text-align: center; font-family: 'Fredoka', sans-serif; font-size: 2rem; margin-bottom: 30px; color: var(--primary); }

        .menu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; }

        .menu-card { 
            background: white; 
            border-radius: 25px; 
            overflow: hidden; 
            box-shadow: 0 10px 20px rgba(0,0,0,0.05); 
            transition: 0.3s;
            border: 2px solid transparent;
        }
        .menu-card:hover { transform: translateY(-10px); border-color: var(--secondary); }

        .menu-img { width: 100%; height: 200px; object-fit: cover; background: #eee; }

        .menu-info { padding: 20px; text-align: center; }
        .menu-info h3 { margin-bottom: 10px; font-size: 1.3rem; }
        .price { font-weight: 700; color: var(--primary); font-size: 1.4rem; margin-bottom: 15px; display: block; }

        .btn-wa { 
            display: inline-block; 
            background-color: #25D366; 
            color: white; 
            padding: 10px 20px; 
            border-radius: 50px; 
            text-decoration: none; 
            font-weight: bold; 
            transition: 0.3s;
        }
        .btn-wa:hover { background-color: #128C7E; transform: scale(1.05); }

        .contact-section { background: white; margin-top: 50px; padding: 30px; border-radius: 25px; text-align: center; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        .social-links a { margin: 0 15px; font-size: 1.5rem; color: var(--primary); text-decoration: none; }

        footer { text-align: center; padding: 30px; color: #888; font-size: 0.9rem; }
    </style>
